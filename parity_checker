module parity_checker(
    input  logic pop_valid_o,
    input  logic [7:0] pop_data_o,
    input  logic parity_bit,

    output logic valid_o,parity_c,
    output logic [7:0] data_o
);

//logic parity_c;

always_comb begin
    parity_c = (^pop_data_o) ^ parity_bit;

    if (pop_valid_o && (parity_c == 0))
        data_o = pop_data_o;
    else
        data_o = 8'd0;
end

assign valid_o = (parity_c == 0);

endmodule
